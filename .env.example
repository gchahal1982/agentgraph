# AgentGraph environment configuration (copy to .env and edit).
# All variables are optional except a provider key when using a hosted model.

# --- LLM ---
# Provider: openai | anthropic | ollama
AG_LLM_PROVIDER=openai
# Model name (defaults per provider: openai=gpt-4o-mini, anthropic=claude-3-5-haiku, ollama=llama3.3)
AG_LLM_MODEL=gpt-4o-mini
# Provider API key (required for hosted providers).
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# For a local model, set AG_LLM_PROVIDER=ollama and run Ollama; no key needed.
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Storage (durable by default) ---
# SQLite (single node, zero external deps):
AG_STORAGE_URL=sqlite:///./data/agentgraph.db
# Postgres (multi-node):
# AG_STORAGE_URL=postgresql://agentgraph:agentgraph@localhost:5432/agentgraph

# --- HTTP server ---
# Bearer token required on all privileged routes. Unset = open mode (dev only).
AG_API_KEY=
AG_HOST=0.0.0.0
AG_PORT=8080
AG_LOG_LEVEL=info
